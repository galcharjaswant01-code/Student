# =============================================
# Student Management System - Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# Django Core
SECRET_KEY=django-insecure-dev-key-change-in-production-please
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================
# Database - PostgreSQL
# =============================================
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/student_management

# =============================================
# AI APIs
# =============================================
GEMINI_API_KEY=AIzaSyDTDltvt0uuS8T827ozKFznZgifPHjjfc0
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_URL=http://localhost:11434

# =============================================
# Redis (Channels + Celery Broker)
# =============================================
REDIS_URL=redis://127.0.0.1:6379/0

# =============================================
# Email
# =============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@sms.local

# =============================================
# Google OAuth (optional)
# =============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================
# File Storage (optional - Cloudinary)
# =============================================
CLOUDINARY_URL=

# =============================================
# Frontend URL (for email links)
# =============================================
FRONTEND_URL=http://localhost:5173
